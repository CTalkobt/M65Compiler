; Test: Opcode execution validation
; Assembles a series of instruction sequences, executes in mmemu,
; and writes results to $4000+ for verification.
; Each test writes a 1-byte result; $AA = sentinel at end.

.org $2000

    ; results pointer
    results = $4000

; =====================================================================
; Test 0: LDA immediate + STA absolute
; Expected: $4000 = $42
; =====================================================================
    lda #$42
    sta results

; =====================================================================
; Test 1: LDX immediate + STX absolute
; Expected: $4001 = $7F
; =====================================================================
    ldx #$7F
    stx results+1

; =====================================================================
; Test 2: LDY immediate + STY absolute
; Expected: $4002 = $33
; =====================================================================
    ldy #$33
    sty results+2

; =====================================================================
; Test 3: LDZ immediate + STZ (store zero to absolute)
; Expected: $4003 = $00
; =====================================================================
    lda #$FF
    sta results+3      ; set to $FF first
    stz results+3      ; STZ stores zero

; =====================================================================
; Test 4: TAX / TXA transfers
; Expected: $4004 = $AB
; =====================================================================
    lda #$AB
    tax                 ; X = $AB
    lda #$00            ; clear A
    txa                 ; A = $AB again
    sta results+4

; =====================================================================
; Test 5: TAY / TYA transfers
; Expected: $4005 = $CD
; =====================================================================
    lda #$CD
    tay                 ; Y = $CD
    lda #$00
    tya                 ; A = $CD
    sta results+5

; =====================================================================
; Test 6: ADC with carry clear (simple addition)
; Expected: $4006 = $30 (= $10 + $20)
; =====================================================================
    clc
    lda #$10
    adc #$20            ; A = $30
    sta results+6

; =====================================================================
; Test 7: SBC (subtraction)
; Expected: $4007 = $15 (= $35 - $20)
; =====================================================================
    sec
    lda #$35
    sbc #$20            ; A = $15
    sta results+7

; =====================================================================
; Test 8: AND immediate
; Expected: $4008 = $0F
; =====================================================================
    lda #$FF
    and #$0F            ; A = $0F
    sta results+8

; =====================================================================
; Test 9: ORA immediate
; Expected: $4009 = $F3
; =====================================================================
    lda #$F0
    ora #$03            ; A = $F3
    sta results+9

; =====================================================================
; Test 10: EOR immediate
; Expected: $400A = $55
; =====================================================================
    lda #$FF
    eor #$AA            ; A = $55
    sta results+10

; =====================================================================
; Test 11: ASL accumulator (shift left)
; Expected: $400B = $80 (= $40 << 1)
; =====================================================================
    lda #$40
    asl a               ; A = $80
    sta results+11

; =====================================================================
; Test 12: LSR accumulator (shift right)
; Expected: $400C = $20 (= $40 >> 1)
; =====================================================================
    lda #$40
    lsr a               ; A = $20
    sta results+12

; =====================================================================
; Test 13: ROL accumulator (carry=0)
; Expected: $400D = $02 (= $01 ROL with C=0)
; =====================================================================
    clc
    lda #$01
    rol a               ; A = $02 (bit 0 gets 0 from carry)
    sta results+13

; =====================================================================
; Test 14: ROR accumulator (carry=1)
; Expected: $400E = $C0 (= $80 ROR with C=1 → bit 7=1, bit 0→carry)
; =====================================================================
    sec
    lda #$80
    ror a               ; A = $C0 (carry→bit7=1, $80>>1=$40, | $80 = $C0)
    sta results+14

; =====================================================================
; Test 15: INC A (45GS02: INC accumulator = INA)
; Expected: $400F = $06
; =====================================================================
    lda #$05
    inc a               ; A = $06
    sta results+15

; =====================================================================
; Test 16: DEC A (45GS02: DEA)
; Expected: $4010 = $09
; =====================================================================
    lda #$0A
    dec a               ; A = $09
    sta results+16

; =====================================================================
; Test 17: INX / DEX
; Expected: $4011 = $10
; =====================================================================
    ldx #$0F
    inx                 ; X = $10
    txa
    sta results+17

; =====================================================================
; Test 18: INY / DEY
; Expected: $4012 = $1F
; =====================================================================
    ldy #$20
    dey                 ; Y = $1F
    tya
    sta results+18

; =====================================================================
; Test 19: PHA / PLA (stack round-trip)
; Expected: $4013 = $99
; =====================================================================
    lda #$99
    pha
    lda #$00            ; clobber A
    pla                 ; A = $99
    sta results+19

; =====================================================================
; Test 20: PHX / PLX (stack round-trip)
; Expected: $4014 = $77
; =====================================================================
    ldx #$77
    phx
    ldx #$00
    plx                 ; X = $77
    txa
    sta results+20

; =====================================================================
; Test 21: BEQ taken (zero flag set)
; Expected: $4015 = $01
; =====================================================================
    lda #$00            ; sets Z flag
    beq @beq_taken
    lda #$FF            ; should be skipped
@beq_taken:
    lda #$01
    sta results+21

; =====================================================================
; Test 22: BNE taken (zero flag clear)
; Expected: $4016 = $01
; =====================================================================
    lda #$01            ; clears Z flag
    bne @bne_taken
    lda #$FF
@bne_taken:
    lda #$01
    sta results+22

; =====================================================================
; Test 23: BCS taken (carry set)
; Expected: $4017 = $01
; =====================================================================
    sec
    bcs @bcs_taken
    lda #$FF
@bcs_taken:
    lda #$01
    sta results+23

; =====================================================================
; Test 24: BCC taken (carry clear)
; Expected: $4018 = $01
; =====================================================================
    clc
    bcc @bcc_taken
    lda #$FF
@bcc_taken:
    lda #$01
    sta results+24

; =====================================================================
; Test 25: CMP sets flags correctly (equal)
; Expected: $4019 = $01
; =====================================================================
    lda #$42
    cmp #$42            ; Z=1 (equal)
    bne @cmp_fail
    lda #$01
    sta results+25
    bra @cmp_done
@cmp_fail:
    lda #$00
    sta results+25
@cmp_done:

; =====================================================================
; Test 26: CMP sets carry (A >= operand)
; Expected: $401A = $01
; =====================================================================
    lda #$50
    cmp #$30            ; C=1 (A >= operand)
    bcc @cmp2_fail
    lda #$01
    sta results+26
    bra @cmp2_done
@cmp2_fail:
    lda #$00
    sta results+26
@cmp2_done:

; =====================================================================
; Test 27: JSR / RTS round-trip
; Expected: $401B = $EE
; =====================================================================
    jsr @subroutine
    sta results+27
    bra @jsr_done
@subroutine:
    lda #$EE
    rts
@jsr_done:

; =====================================================================
; Test 28: Zero-page load/store
; Expected: $401C = $5A
; =====================================================================
    lda #$5A
    sta $20             ; store to ZP
    lda #$00            ; clobber A
    lda $20             ; reload from ZP
    sta results+28

; =====================================================================
; Test 29: Absolute indexed X load
; Expected: $401D = $BB
; =====================================================================
    lda #$BB
    sta results+31      ; put $BB at results+31
    ldx #$1F            ; offset 31
    lda results,x       ; load from results+31
    sta results+29

; =====================================================================
; Test 30: BPL / BMI (negative flag)
; Expected: $401E = $01
; =====================================================================
    lda #$80            ; negative (bit 7 set)
    bmi @bmi_taken
    lda #$00
    bra @bmi_done
@bmi_taken:
    lda #$01
@bmi_done:
    sta results+30

; =====================================================================
; Sentinel: $AA at results+32
; =====================================================================
    lda #$AA
    sta results+32

    brk
